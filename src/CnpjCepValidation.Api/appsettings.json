{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Validation": {
    "PrimaryCepProvider": "BrasilApi",
    "CacheTtlMinutes": 5,
    "NegativeCacheTtlMinutes": 1,
    "TimeoutMs": 800,
    "CnpjRetryCount": 2,
    "CepPrimaryRetryCount": 2,
    "CepSecondaryRetryCount": 1
  },
  "ExternalApis": {
    "BrasilApiBaseUrl": "https://brasilapi.com.br",
    "ViaCepBaseUrl": "https://viacep.com.br"
  }
}
